<Page x:Class="UnoManipulationIssue.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoManipulationIssue"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
      SizeChanged="OnPageSizeChanged">
  <ScrollViewer IsTabStop="True">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Margin="0,32,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
        <TextBlock AutomationProperties.AutomationId="HelloTextBlock"
                   Text="Manipulate touch pad and press button at the same time"
                   HorizontalAlignment="Center" />
      </StackPanel>

            <Grid Grid.Row="1" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!--Touch pad-->
                <Ellipse x:Name="touchPad" Grid.Row="1" Grid.Column="0" Margin="64,64,32,32" Height="200" Width="200" Stroke="LimeGreen" StrokeThickness="2" Fill="Yellow"
                    ManipulationStarted="Path_ManipulationStarted"
                  ManipulationDelta="Path_ManipulationDelta"
                  ManipulationCompleted="Path_ManipulationCompleted"/>

                <Grid Grid.Row="1" Grid.Column="1" SizeChanged="OnDrawingSurfaceSizeChanged" Background="Wheat">
                    <!--Moving sprite-->
                    <SymbolIcon  Symbol="Send" HorizontalAlignment="Left" VerticalAlignment="Top" >
                        <SymbolIcon.RenderTransform>
                            <TranslateTransform X="{x:Bind VM.XPosition, Mode=OneWay}"
                                                Y="{x:Bind VM.YPosition, Mode=OneWay}" />
                        </SymbolIcon.RenderTransform>
                    </SymbolIcon>
                </Grid>

                <!--Action Button-->
                <Button x:Name="actionButton" Grid.Row="1" Grid.Column="2" Margin="16,16,32,32"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StrikeCommand, Mode=OneWay}"
                        Tag="Hit Me">
                    <Button.Template>
                        <ControlTemplate>
                            <Grid>
                                <Ellipse x:Name="ellipse" Height="60" Width="60" Stroke="LimeGreen" StrokeThickness="2" Fill="Red"/>
                                <TextBlock x:Name="displayText" Text="{TemplateBinding Tag}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <VisualStateManager.VisualStateGroups>

                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="ellipse.Fill" Value="Gray" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="ellipse.Stroke" Value="GreenYellow" />
                                                <Setter Target="ellipse.StrokeThickness" Value="5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="ellipse.Fill" Value="DeepPink" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind VM.Response, Mode=OneWay}" />
                <Button Content="Stop"
                        Command="{x:Bind VM.StopCommand}"
                        Padding="4"
                        Margin="20,4,0,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Red"
                        CornerRadius="2"
                        Foreground="White"/>

            </StackPanel>
    </Grid>

        <VisualStateManager.VisualStateGroups>

            <!-- Visual states reflect the application's view state -->
            <VisualStateGroup>
                <VisualState x:Name="Landscape">
                    <VisualState.Setters>
                        <Setter Target="touchPad.(Grid.Row)" Value="1" />
                        <Setter Target="touchPad.(Grid.Column)" Value="0" />
                        <Setter Target="actionButton.(Grid.Row)" Value="1" />
                        <Setter Target="actionButton.(Grid.Column)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Portrait">
                    <VisualState.Setters>
                        <Setter Target="touchPad.(Grid.Row)" Value="0" />
                        <Setter Target="touchPad.(Grid.Column)" Value="1" />
                        <Setter Target="actionButton.(Grid.Row)" Value="2" />
                        <Setter Target="actionButton.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

    </ScrollViewer>
</Page>
